      "source": [
        "import yfinance as yf\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Pick a company\n",
        "ticker = \"SOFI\"\n",
        "\n",
        "# Get data\n",
        "data = yf.download(ticker, start=\"2023-01-01\", end=\"2025-01-01\")\n",
        "\n",
        "# Show first rows\n",
        "print(data.head())\n",
        "\n",
        "# Plot closing price\n",
        "data[\"Close\"].plot(title=f\"{ticker} Stock Price\")\n",
        "plt.show()"
      ]
    }
